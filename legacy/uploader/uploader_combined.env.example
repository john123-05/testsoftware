# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# Bilder (bestehender Bucket)
# Kann auch einfach BUCKET heißen, damit es zu deiner alten Struktur passt
IMAGE_BUCKET=test
# Optionaler Legacy-Fallback, wenn du IMAGE_BUCKET nicht nutzt
BUCKET=test

# Neuer Bucket für Logs / Rohdaten
DATA_BUCKET=daten

# Bestehende Bild-Logik
WEBOUT_DIR=C:\liftpic\fotos\webout
OUT_DIR=C:\liftpic\fotos\out
TARGET_DIR=C:\liftpic\fotos\webout1

# Falls du TARGET_DIR nicht setzen willst, kannst du SOURCE_DIR als Fallback nutzen
SOURCE_DIR=C:\liftpic\fotos\webout1

POLL_SECONDS=2
BRIDGE_POLL_SECONDS=0.5
PER_FILE_DELAY=0.2
MAX_RETRIES=5
RETRY_DELAY=2
STATE_FILE=uploader_state.json
LOOKBACK_SECONDS=120
MAX_TIME_DELTA_S=10

# Dateien, die immer länger werden
APPEND_SOURCES_JSON=[
  {"path":"C:\\liftpic\\samuel_neu\\Statistic.txt","source_type":"statistic"},
  {"path":"C:\\liftpic\\samuel_neu\\debug.log","source_type":"debug"},
  {"path":"C:\\liftpic\\samuel_neu\\errors.log","source_type":"errors"},
  {"path":"C:\\liftpic\\3GerTis\\3gerlog.txt","source_type":"3gerlog"}
]

# Ordner, in denen neue Dateien auftauchen
DROP_SOURCES_JSON=[
  {"dir":"C:\\liftpic\\terminal","pattern":"ZvtLog_*.txt","source_type":"zvtlog"},
  {"dir":"C:\\liftpic\\samuel_neu\\Log","pattern":"NRI.CoinCharger_*.txt","source_type":"coincharger"}
]
